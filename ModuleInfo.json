{
  "Name": "Custom Storybooks",
  "Author": "Aba Gamer, Super Hackio",
  "Description": "SMG1 port: PictureBook",
  "InstallDependencies": [ "Syati_ObjectFactories" ],
  "SupportedGames": [ "SB4" ],
  "RequiredAPIs": [ "Syati_ExtGameData_API" ],
  "OptionalAPIs": [ "GalaxyLevelEngine_API" ],
  "BuildTasks": [
    {
      "Task": "Copy",
      "From": "disc/",
      "To": "../../Output/disc/"
    }
  ],
  "ModuleData": [
    {
      "ProductMapObj": [
        {
          "Name": "PictureBook",
          "Function": "createExtActor<RosettaPictureBook>",
          "Include": "RosettaPictureBook.h"
        }
      ],
      "NewSaveChunk": [
        {
          "ChunkMemberType": "PictureBookDataStorage",
          "ChunkMemberName": "mPictureBookDataStorage",
          "ChunkCreationFunc": "createBinaryChunk<PictureBookDataStorage>",
          "Include": "PictureBookDataStorage.h"
        }
      ],
      "GLE__isJMapEntryProgressComplete": [
        {
          "Name": "PictureBookJMapProgress",
          "Function": "PictureBookDataUtil::isReadChapterJMapProgress",
          "Include": "PictureBookDataStorage.h"
        }
      ]
    }
  ]
}